# Copy this file to /etc/red-flower-garden/object-storage.env on the server.
# Use a dedicated private OSS bucket for Red Flower Garden app objects.
# Do not reuse gh-oss-attachments.env, and do not commit the filled file.

ALIYUN_OSS_ACCESS_KEY_ID=replace-with-dedicated-ram-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=replace-with-dedicated-ram-access-key-secret
ALIYUN_OSS_BUCKET=mozhi-red-flower-garden
ALIYUN_OSS_REGION=oss-cn-guangzhou
ALIYUN_OSS_ENDPOINT=https://oss-cn-guangzhou.aliyuncs.com
ALIYUN_OSS_PREFIX=red-flower-garden/
