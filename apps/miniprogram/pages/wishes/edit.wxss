page {
  background: #fff8de;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  color: #2f382d;
  background:
    linear-gradient(180deg, rgba(255, 248, 222, 0.96), rgba(237, 251, 220, 0.96) 52%, #f8ffe8),
    #fff8de;
}

.sheet {
  min-height: calc(100vh - 48rpx);
  box-sizing: border-box;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(72, 106, 65, 0.14);
}

.sheet-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-action {
  color: #e24b45;
  font-size: 28rpx;
  font-weight: 900;
}

.title {
  margin-top: 42rpx;
  color: #2d3b29;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.12;
}

.message {
  margin-top: 14rpx;
  color: #6d7a66;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.45;
}

.field {
  margin-top: 38rpx;
}

.field-label {
  margin-left: 8rpx;
  color: #7f8a78;
  font-size: 26rpx;
  font-weight: 900;
}

.input,
.cost-input {
  box-sizing: border-box;
  height: 84rpx;
  padding: 0 22rpx;
  border: 1rpx solid #dbe8cc;
  border-radius: 22rpx;
  color: #2f382d;
  font-size: 30rpx;
  font-weight: 900;
  background: #fbfff1;
}

.input {
  width: 100%;
  margin-top: 14rpx;
}

.cost-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 190rpx;
  gap: 12rpx;
  margin-top: 14rpx;
}

.cost-input {
  width: 100%;
}

.stepper {
  display: grid;
  grid-template-columns: 1fr 1rpx 1fr;
  align-items: center;
  height: 84rpx;
  border-radius: 22rpx;
  background: #e9f3ec;
}

.stepper-button {
  color: #596552;
  font-size: 42rpx;
  font-weight: 900;
  text-align: center;
  line-height: 84rpx;
}

.stepper-divider {
  height: 42rpx;
  background: rgba(89, 101, 82, 0.22);
}

.choice-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 14rpx;
}

.choice {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-height: 78rpx;
  border-radius: 22rpx;
  color: #61715d;
  font-size: 27rpx;
  font-weight: 900;
  background: #f7faf5;
}

.choice-active {
  color: #ffffff;
  background: #e24b45;
}

.choice-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  background: rgba(255, 255, 255, 0.36);
}

.switch-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 34rpx;
  color: #596552;
  font-size: 27rpx;
  font-weight: 900;
}

.future-panel {
  margin-top: 34rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f7faf5;
}

.future-title {
  color: #2f382d;
  font-size: 26rpx;
  font-weight: 900;
}

.future-line {
  margin-top: 8rpx;
  color: #6d7a66;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.45;
}

.save-button {
  width: 420rpx;
  min-height: 82rpx;
  margin: 44rpx auto 0;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 82rpx;
  background: #e24b45;
}
