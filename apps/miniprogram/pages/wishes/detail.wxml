<view class="page">
  <view class="hero">
    <view class="eyebrow">心愿详情</view>
    <view class="title">{{title}}</view>
    <view class="meta-row">
      <view class="meta-pill">{{flowerCost}} 朵</view>
      <view class="meta-pill">{{kindText}}</view>
      <view class="meta-pill">{{pinnedText}}</view>
    </view>
    <view class="progress">
      <view class="progress-fill" style="width: {{progress}}%;"></view>
    </view>
    <view class="message">{{message}}</view>
    <view class="button-row">
      <view class="action-button primary {{canRedeem ? '' : 'action-disabled'}}" bindtap="redeemCurrentWish">兑换</view>
      <view class="action-button secondary" bindtap="openWishList">管理</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">小红花</view>
    <view class="balance-line">当前可用：{{availableFlowers}} 朵</view>
    <view class="balance-line">完成进度：{{progress}}%</view>
  </view>

  <view class="section">
    <view class="section-title">兑换记录</view>
    <view wx:if="{{redemptions.length === 0}}" class="empty">这个心愿还没有兑换记录。</view>
    <view wx:for="{{redemptions}}" wx:key="id" class="history-item">
      <view class="history-title">{{item.statusText}}</view>
      <view class="history-meta">{{item.timeText}}</view>
    </view>
  </view>
</view>
