<view class="page">
  <view class="hero">
    <view class="eyebrow">心愿详情</view>
    <view class="title">{{title}}</view>
    <view class="meta-row">
      <view class="meta-pill">{{flowerCost}} 朵</view>
      <view class="meta-pill">{{kindText}}</view>
      <view class="meta-pill">{{pinnedText}}</view>
    </view>
    <view class="progress">
      <view class="progress-fill" style="width: {{progress}}%;"></view>
    </view>
    <view class="message">{{message}}</view>
    <image wx:if="{{imageUrl}}" class="wish-hero-image" src="{{imageUrl}}" mode="aspectFill"></image>
    <view wx:if="{{!readonly}}" class="button-row">
      <view class="action-button primary {{canRedeem ? '' : 'action-disabled'}}" bindtap="redeemCurrentWish">兑换</view>
      <view wx:if="{{!readonly}}" class="action-button secondary" bindtap="editWish">修改</view>
    </view>
  </view>

  <view wx:if="{{description || linkUrl}}" class="section">
    <view class="section-title">心愿信息</view>
    <view wx:if="{{description}}" class="description">{{description}}</view>
    <view wx:if="{{linkUrl}}" class="link-copy-button" bindtap="copyWishLink">复制链接</view>
  </view>

  <view class="section">
    <view class="section-title">小红花</view>
    <view class="balance-line">当前可用：{{availableFlowers}} 朵</view>
    <view class="balance-line">完成进度：{{progress}}%</view>
  </view>

  <parent-control-panel id="parentControl" />
</view>
