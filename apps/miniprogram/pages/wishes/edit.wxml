<view class="page">
  <view class="sheet">
    <view class="sheet-nav">
      <view class="nav-action" bindtap="cancel">取消</view>
      <view wx:if="{{parentControlReady}}" class="nav-action {{imageUploading ? 'nav-action-disabled' : ''}}" bindtap="saveWish">保存</view>
    </view>

    <view class="title">{{modeText}}</view>
    <view class="message">{{message}}</view>

    <block wx:if="{{parentControlReady}}">
      <view class="field">
        <view class="field-label">名称</view>
        <input class="input" value="{{titleInput}}" bindinput="updateTitle" placeholder="例如：周末坐旋转木马" />
      </view>

      <view class="field">
        <view class="field-label">图片</view>
        <view class="image-field">
          <image wx:if="{{imageUrlInput}}" class="wish-image-preview" src="{{imageUrlInput}}" mode="aspectFill"></image>
          <view wx:else class="image-placeholder">心愿图片</view>
          <view class="image-actions">
            <view class="image-action" bindtap="chooseWishImage">{{imageUploading ? "上传中" : imageUrlInput ? "换图" : "上传图片"}}</view>
            <view wx:if="{{imageUrlInput}}" class="image-action muted" bindtap="removeWishImage">移除</view>
          </view>
        </view>
        <input
          class="input compact-input"
          value="{{imageUrlInput}}"
          bindinput="updateImageUrl"
          placeholder="或粘贴图片链接"
        />
      </view>

      <view class="field">
        <view class="field-label">花费小红花</view>
        <view class="cost-row">
          <input
            class="cost-input"
            type="number"
            value="{{flowerCostInput}}"
            bindinput="updateFlowerCost"
            placeholder="需要小红花"
          />
          <view class="stepper">
            <view class="stepper-button" bindtap="decreaseFlowerCost">-</view>
            <view class="stepper-divider"></view>
            <view class="stepper-button" bindtap="increaseFlowerCost">+</view>
          </view>
        </view>
      </view>

      <view class="field">
        <view class="field-label">类型</view>
        <view class="choice-row">
          <view
            class="choice {{kindInput === 'one_time' ? 'choice-active' : ''}}"
            data-kind="one_time"
            bindtap="updateKind"
          >
            <view class="choice-dot">{{kindInput === "one_time" ? "✓" : ""}}</view>
            一次性
          </view>
          <view
            class="choice {{kindInput === 'repeating' ? 'choice-active' : ''}}"
            data-kind="repeating"
            bindtap="updateKind"
          >
            <view class="choice-dot">{{kindInput === "repeating" ? "✓" : ""}}</view>
            可重复
          </view>
        </view>
      </view>

      <view class="switch-line">
        <text>首页置顶泡泡</text>
        <switch checked="{{pinnedInput}}" bindchange="updatePinned" />
      </view>

      <view class="field">
        <view class="field-label">链接</view>
        <input
          class="input"
          value="{{linkUrlInput}}"
          bindinput="updateLinkUrl"
          placeholder="商品或活动链接，可选"
        />
      </view>

      <view class="field">
        <view class="field-label">详细描述</view>
        <textarea
          class="textarea"
          value="{{descriptionInput}}"
          bindinput="updateDescription"
          maxlength="1000"
          placeholder="写下心愿细节、规格、颜色、购买备注等"
        ></textarea>
      </view>

      <button class="save-button" loading="{{loading || imageUploading}}" bindtap="saveWish">保存心愿</button>
    </block>
  </view>
  <parent-control-panel id="parentControl" />
</view>
