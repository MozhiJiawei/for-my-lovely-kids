<view class="page">
  <view class="sheet">
    <view class="sheet-nav">
      <view class="nav-action" bindtap="cancel">取消</view>
      <view class="nav-action" bindtap="saveWish">保存</view>
    </view>

    <view class="title">{{modeText}}</view>
    <view class="message">{{message}}</view>

    <view class="field">
      <view class="field-label">名称</view>
      <input class="input" value="{{titleInput}}" bindinput="updateTitle" placeholder="例如：周末坐旋转木马" />
    </view>

    <view class="field">
      <view class="field-label">花费小红花</view>
      <view class="cost-row">
        <input
          class="cost-input"
          type="number"
          value="{{flowerCostInput}}"
          bindinput="updateFlowerCost"
          placeholder="需要小红花"
        />
        <view class="stepper">
          <view class="stepper-button" bindtap="decreaseFlowerCost">-</view>
          <view class="stepper-divider"></view>
          <view class="stepper-button" bindtap="increaseFlowerCost">+</view>
        </view>
      </view>
    </view>

    <view class="field">
      <view class="field-label">类型</view>
      <view class="choice-row">
        <view
          class="choice {{kindInput === 'one_time' ? 'choice-active' : ''}}"
          data-kind="one_time"
          bindtap="updateKind"
        >
          <view class="choice-dot">{{kindInput === "one_time" ? "✓" : ""}}</view>
          一次性
        </view>
        <view
          class="choice {{kindInput === 'repeating' ? 'choice-active' : ''}}"
          data-kind="repeating"
          bindtap="updateKind"
        >
          <view class="choice-dot">{{kindInput === "repeating" ? "✓" : ""}}</view>
          可重复
        </view>
      </view>
    </view>

    <view class="switch-line">
      <text>首页置顶泡泡</text>
      <switch checked="{{pinnedInput}}" bindchange="updatePinned" />
    </view>

    <view class="future-panel">
      <view class="future-title">后续增强</view>
      <view class="future-line">图片、链接、描述会放在这个编辑页继续扩展。</view>
    </view>

    <button class="save-button" loading="{{loading}}" bindtap="saveWish">保存心愿</button>
  </view>
</view>
