page {
  background: #fff8de;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  color: #2f382d;
  background:
    linear-gradient(180deg, rgba(255, 248, 222, 0.96), rgba(237, 251, 220, 0.96) 52%, #f8ffe8),
    #fff8de;
}

.sheet {
  min-height: calc(100vh - 48rpx);
  box-sizing: border-box;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(72, 106, 65, 0.14);
}

.sheet-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-action {
  color: #e24b45;
  font-size: 28rpx;
  font-weight: 900;
}

.eyebrow {
  display: inline-flex;
  margin-top: 42rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #146a36;
  font-size: 22rpx;
  font-weight: 900;
  background: #edf8e8;
}

.title {
  margin-top: 18rpx;
  color: #2d3b29;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.12;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.meta-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #596552;
  font-size: 23rpx;
  font-weight: 900;
  background: #f7faf5;
}

.message {
  margin-top: 14rpx;
  color: #6d7a66;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.45;
}

.field {
  margin-top: 38rpx;
}

.field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.field-label {
  margin-left: 8rpx;
  color: #7f8a78;
  font-size: 26rpx;
  font-weight: 900;
}

.selected-summary {
  flex: 0 0 auto;
  color: #b84a3e;
  font-size: 24rpx;
  font-weight: 900;
}

.weekday-row {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 32rpx;
  color: #9aa195;
  font-size: 24rpx;
  font-weight: 900;
  text-align: center;
}

.calendar-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(72, 106, 65, 0.12);
}

.month-nav {
  display: grid;
  grid-template-columns: 76rpx minmax(0, 1fr) 76rpx;
  align-items: center;
}

.month-button {
  color: #6d7a66;
  font-size: 58rpx;
  font-weight: 800;
  text-align: center;
  line-height: 68rpx;
}

.month-button-disabled {
  color: #c7d0c2;
}

.month-label {
  color: #2f382d;
  font-size: 42rpx;
  font-weight: 900;
  text-align: center;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.day-cell {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  aspect-ratio: 1;
  border-radius: 18rpx;
  border: 4rpx solid transparent;
  box-sizing: border-box;
  color: #2f382d;
  font-size: 28rpx;
  font-weight: 800;
  background: #edf0ea;
}

.day-enabled {
  background: #edf0ea;
}

.day-blank {
  color: transparent;
  background: transparent;
}

.day-disabled {
  color: #2f382d;
}

.day-checkin {
  background: #ffe7a6;
}

.day-today {
  border-color: #e24b45;
}

.day-selected {
  border-color: #e24b45;
}

.calendar-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  align-items: center;
  justify-content: center;
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf2e8;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #6d7a66;
  font-size: 22rpx;
  font-weight: 800;
}

.legend-swatch {
  width: 28rpx;
  height: 22rpx;
  border-radius: 7rpx;
}

.checkin-swatch {
  background: #ffe7a6;
}

.available-swatch {
  background: #edf0ea;
}

.selected-swatch {
  border: 3rpx solid #e24b45;
  box-sizing: border-box;
  background: #edf0ea;
}

.date-picker {
  display: flex;
  align-items: center;
  min-height: 84rpx;
  margin-top: 14rpx;
  padding: 0 22rpx;
  border: 1rpx solid #dbe8cc;
  border-radius: 22rpx;
  box-sizing: border-box;
  color: #2f382d;
  font-size: 30rpx;
  font-weight: 900;
  background: #fbfff1;
}

.hint-panel {
  margin-top: 34rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f7faf5;
}

.hint-title {
  color: #2f382d;
  font-size: 26rpx;
  font-weight: 900;
}

.hint-line {
  margin-top: 8rpx;
  color: #6d7a66;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.45;
}

.save-button {
  width: 420rpx;
  min-height: 82rpx;
  margin: 44rpx auto 0;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 82rpx;
  background: #e24b45;
}
