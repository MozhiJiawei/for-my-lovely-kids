<view class="page">
  <view class="sheet">
    <view class="sheet-nav">
      <view class="nav-action" bindtap="cancel">取消</view>
      <view wx:if="{{parentControlReady}}" class="nav-action" bindtap="saveTask">保存</view>
    </view>

    <view class="title">{{modeText}}</view>
    <view class="message">{{message}}</view>

    <block wx:if="{{parentControlReady}}">
      <view class="field">
        <view class="field-label">名称</view>
        <input class="input" value="{{titleInput}}" bindinput="updateTitle" placeholder="例如：认真刷牙" />
      </view>

      <view class="field">
        <view class="field-label">奖励小红花</view>
        <view class="cost-row">
          <input
            class="cost-input"
            type="number"
            value="{{flowerValueInput}}"
            bindinput="updateFlowerValue"
            placeholder="奖励小红花"
          />
          <view class="stepper">
            <view class="stepper-button" bindtap="decreaseFlowerValue">-</view>
            <view class="stepper-divider"></view>
            <view class="stepper-button" bindtap="increaseFlowerValue">+</view>
          </view>
        </view>
      </view>

      <view class="field">
        <view class="field-label">类型</view>
        <view class="choice-row">
          <view
            class="choice {{kindInput === 'repeating' ? 'choice-active' : ''}}"
            data-kind="repeating"
            bindtap="updateKind"
          >
            <view class="choice-dot">{{kindInput === "repeating" ? "✓" : ""}}</view>
            习惯
          </view>
          <view
            class="choice {{kindInput === 'one_time' ? 'choice-active' : ''}}"
            data-kind="one_time"
            bindtap="updateKind"
          >
            <view class="choice-dot">{{kindInput === "one_time" ? "✓" : ""}}</view>
            目标
          </view>
        </view>
      </view>

      <view class="future-panel">
        <view class="future-title">任务说明</view>
        <view class="future-line">习惯按天重置；目标完成一次后会进入已达成记录。</view>
      </view>

      <button class="save-button" loading="{{loading}}" bindtap="saveTask">保存任务</button>
    </block>
  </view>
  <parent-control-panel id="parentControl" />
</view>
