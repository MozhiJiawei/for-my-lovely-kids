.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 36rpx;
  background: #f7faf5;
}

.header {
  padding-bottom: 24rpx;
}

.eyebrow {
  color: #15803d;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  margin-top: 8rpx;
  color: #213027;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.25;
}

.message {
  margin-top: 16rpx;
  color: #536158;
  font-size: 26rpx;
  line-height: 1.5;
}

.balance-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.balance-box {
  min-width: 0;
  padding: 20rpx 12rpx;
  border: 1rpx solid #d9e7dc;
  border-radius: 8rpx;
  background: #ffffff;
  text-align: center;
}

.balance-label {
  color: #5f6f65;
  font-size: 22rpx;
  line-height: 1.3;
}

.balance-value {
  margin-top: 8rpx;
  color: #c2410c;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.1;
}

.section {
  margin-top: 28rpx;
  padding: 24rpx;
  border: 1rpx solid #d9e7dc;
  border-radius: 8rpx;
  background: #ffffff;
}

.section-title {
  margin-bottom: 16rpx;
  color: #23342a;
  font-size: 30rpx;
  font-weight: 800;
}

.input {
  box-sizing: border-box;
  width: 100%;
  height: 76rpx;
  margin-top: 14rpx;
  padding: 0 20rpx;
  border: 1rpx solid #cfded3;
  border-radius: 8rpx;
  color: #23342a;
  font-size: 28rpx;
  background: #fbfdf9;
}

.status {
  margin-top: 18rpx;
  color: #536158;
  font-size: 26rpx;
  line-height: 1.45;
}

.readonly-line {
  margin-top: 12rpx;
  color: #23342a;
  font-size: 27rpx;
  line-height: 1.45;
}

.option-title {
  margin-top: 24rpx;
  color: #23342a;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.4;
}

.option-item {
  box-sizing: border-box;
  width: 100%;
  margin-top: 12rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #cfded3;
  border-radius: 8rpx;
  background: #f7faf5;
}

.option-selected {
  border-color: #15803d;
  background: #e9f7ee;
}

.option-main {
  color: #23342a;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.45;
}

.option-meta {
  margin-top: 6rpx;
  color: #536158;
  font-size: 24rpx;
  line-height: 1.35;
}

.radio-row {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.radio-label {
  display: flex;
  align-items: center;
  color: #536158;
  font-size: 26rpx;
}

.switch-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  color: #536158;
  font-size: 26rpx;
}

.button-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 18rpx;
}

.button {
  width: 100%;
  min-height: 76rpx;
  border-radius: 8rpx;
  color: #23342a;
  font-size: 26rpx;
  line-height: 76rpx;
  background: #e9f3ec;
}

.primary {
  color: #ffffff;
  background: #15803d;
}

.full {
  margin-top: 18rpx;
}

.empty,
.ledger-line {
  margin-top: 12rpx;
  color: #536158;
  font-size: 25rpx;
  line-height: 1.5;
}

.ledger-line {
  padding: 16rpx;
  border-radius: 8rpx;
  background: #f7faf5;
}

.reset-button {
  margin-top: 28rpx;
  min-height: 76rpx;
  border-radius: 8rpx;
  color: #536158;
  font-size: 26rpx;
  line-height: 76rpx;
  background: #eef5f0;
}
