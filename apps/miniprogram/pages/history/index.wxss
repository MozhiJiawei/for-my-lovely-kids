page {
  background: #f7faf5;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 28rpx 132rpx;
  color: #2f382d;
  background: linear-gradient(180deg, #fff8de 0%, #f8fff0 36%, #f7faf5 100%), #f7faf5;
}

.header {
  padding: 22rpx 0 26rpx;
  text-align: center;
}

.title {
  color: #2d3b29;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.15;
}

.message {
  margin-top: 12rpx;
  color: #6d7a66;
  font-size: 24rpx;
  font-weight: 800;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
}

.summary-card,
.calendar-card,
.day-card,
.detail-card {
  background: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(72, 106, 65, 0.12);
}

.summary-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 190rpx;
  padding: 24rpx 10rpx 18rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.summary-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 16rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 900;
}

.green {
  background: #47bd71;
}

.red {
  background: #e24b45;
}

.blue {
  background: #58a7e8;
}

.summary-number {
  margin-top: 18rpx;
  color: #2f382d;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1;
}

.summary-label {
  margin-top: 16rpx;
  color: #8b9685;
  font-size: 22rpx;
  font-weight: 800;
}

.filter-section {
  position: relative;
  margin-top: 24rpx;
}

.filter-trigger {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  gap: 16rpx;
  align-items: center;
  min-height: 74rpx;
  padding: 0 22rpx;
  border: 2rpx solid #b8c8af;
  border-radius: 10rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(72, 106, 65, 0.08);
}

.filter-title {
  color: #596552;
  font-size: 24rpx;
  font-weight: 900;
}

.filter-value {
  overflow: hidden;
  min-width: 0;
  color: #2f382d;
  font-size: 26rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-arrow {
  color: #596552;
  font-size: 26rpx;
  font-weight: 900;
}

.filter-panel {
  position: absolute;
  z-index: 10;
  top: 86rpx;
  left: 0;
  right: 0;
  padding: 22rpx;
  border: 2rpx solid #7e8b78;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 46rpx rgba(47, 56, 45, 0.2);
}

.filter-panel-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 12rpx;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #edf2e8;
}

.filter-action {
  color: #2f6d3e;
  font-size: 24rpx;
  font-weight: 900;
}

.filter-action.muted {
  color: #596552;
}

.filter-search {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 48rpx;
  align-items: center;
  height: 68rpx;
  margin-top: 18rpx;
  border: 3rpx solid #2f382d;
  background: #ffffff;
}

.filter-search-input {
  min-width: 0;
  height: 68rpx;
  padding: 0 14rpx;
  color: #2f382d;
  font-size: 26rpx;
  font-weight: 800;
}

.filter-search-clear {
  color: #2f382d;
  font-size: 32rpx;
  font-weight: 900;
  text-align: center;
}

.filter-list {
  max-height: 320rpx;
  margin-top: 14rpx;
  overflow: hidden;
  border: 1rpx solid #dfe7da;
}

.filter-option {
  display: grid;
  grid-template-columns: 46rpx minmax(0, 1fr);
  gap: 12rpx;
  align-items: center;
  min-height: 58rpx;
  padding: 0 12rpx;
  color: #2f382d;
  font-size: 25rpx;
  font-weight: 800;
}

.filter-option-selected {
  background: #f0f7ec;
}

.filter-check {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 30rpx;
  height: 30rpx;
  border: 2rpx solid #8b9685;
  color: #2f6d3e;
  font-size: 22rpx;
  font-weight: 900;
}

.filter-option-text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-empty {
  padding: 34rpx 0;
  color: #9aa195;
  font-size: 25rpx;
  font-weight: 800;
  text-align: center;
}

.filter-buttons {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.filter-button {
  min-width: 108rpx;
  padding: 14rpx 18rpx;
  border: 2rpx solid #7e8b78;
  border-radius: 10rpx;
  font-size: 25rpx;
  font-weight: 900;
  text-align: center;
}

.filter-button.confirm {
  color: #ffffff;
  border-color: #2f6d3e;
  background: #47bd71;
}

.filter-button.cancel {
  color: #596552;
  background: #ffffff;
}

.selected-habit {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
  color: #6d7a66;
  font-size: 23rpx;
  font-weight: 900;
}

.habit-clear {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 900;
  background: #e24b45;
}

.calendar-card {
  margin-top: 24rpx;
  padding: 28rpx 24rpx 24rpx;
  border-radius: 30rpx;
}

.month-nav {
  display: grid;
  grid-template-columns: 76rpx minmax(0, 1fr) 76rpx;
  align-items: center;
}

.month-button {
  color: #6d7a66;
  font-size: 58rpx;
  font-weight: 800;
  text-align: center;
  line-height: 68rpx;
}

.month-label {
  color: #2f382d;
  font-size: 42rpx;
  font-weight: 900;
  text-align: center;
}

.weekday-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 12rpx;
}

.weekday-row {
  margin-top: 32rpx;
  color: #9aa195;
  font-size: 24rpx;
  font-weight: 900;
  text-align: center;
}

.calendar-grid {
  margin-top: 18rpx;
}

.day-cell {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  aspect-ratio: 1;
  border: 4rpx solid transparent;
  border-radius: 18rpx;
  box-sizing: border-box;
  color: #2f382d;
  font-size: 28rpx;
  font-weight: 800;
  background: #edf0ea;
}

.day-blank {
  background: transparent;
}

.day-checkin {
  background: #ffe7a6;
}

.day-today {
  border-color: #f0a04b;
}

.day-selected {
  border-color: #e24b45;
}

.day-markers {
  position: absolute;
  bottom: 8rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 6rpx;
}

.day-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.goal-dot {
  background: #47bd71;
}

.wish-dot {
  background: #e24b45;
}

.calendar-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  align-items: center;
  justify-content: center;
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf2e8;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #6d7a66;
  font-size: 22rpx;
  font-weight: 800;
}

.legend-swatch {
  width: 28rpx;
  height: 22rpx;
  border-radius: 7rpx;
}

.habit-swatch {
  background: #ffe7a6;
}

.legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.day-card,
.detail-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
}

.day-title,
.detail-title {
  color: #2f382d;
  font-size: 34rpx;
  font-weight: 900;
}

.summary-metrics {
  display: grid;
  gap: 16rpx;
  margin-top: 24rpx;
}

.event-metrics {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.flower-metrics {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.summary-metric {
  min-width: 0;
  padding: 14rpx 8rpx;
  border-radius: 20rpx;
  background: rgba(233, 241, 225, 0.82);
  text-align: center;
}

.summary-divider {
  height: 1rpx;
  margin-top: 16rpx;
  background: #edf2e8;
}

.metric-value {
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.15;
}

.metric-label {
  margin-top: 8rpx;
  color: #7f8d78;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.25;
  white-space: nowrap;
}

.habit {
  color: #d9a83d;
}

.gain-result,
.goal {
  color: #47bd71;
}

.spend-result,
.wish {
  color: #e24b45;
}

.empty {
  min-height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9aa195;
  font-size: 28rpx;
  font-weight: 800;
}

.detail-row {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr) 84rpx;
  gap: 18rpx;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf2e8;
}

.detail-row-manageable {
  grid-template-columns: 112rpx minmax(0, 1fr) 112rpx;
}

.detail-row:last-child {
  border-bottom: 0;
}

.detail-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 54rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 900;
}

.detail-habit {
  color: #6d5c1a;
  background: #ffe7a6;
}

.detail-goal {
  background: #47bd71;
}

.detail-wish {
  background: #e24b45;
}

.detail-name {
  color: #2f382d;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.3;
}

.detail-meta {
  margin-top: 8rpx;
  color: #6d7a66;
  font-size: 24rpx;
  font-weight: 800;
}

.detail-view-indicator {
  color: #e24b45;
  font-size: 23rpx;
  font-weight: 900;
  text-align: right;
}

.detail-actions {
  grid-column: 3;
  grid-row: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  align-items: stretch;
}

.detail-action {
  min-width: 0;
  padding: 10rpx 0;
  border-radius: 999rpx;
  color: #596552;
  font-size: 22rpx;
  font-weight: 900;
  text-align: center;
  background: #e9f3ec;
}

.detail-action.danger {
  color: #ffffff;
  background: #e24b45;
}

.edit-mask {
  position: fixed;
  z-index: 18;
  inset: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 28rpx;
  box-sizing: border-box;
  background: rgba(37, 52, 34, 0.36);
}

.edit-panel {
  width: 100%;
  padding: 34rpx 30rpx 30rpx;
  border-radius: 34rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 24rpx 70rpx rgba(45, 59, 41, 0.24);
}

.edit-title {
  color: #2f382d;
  font-size: 34rpx;
  font-weight: 900;
  text-align: center;
}

.edit-record {
  margin-top: 24rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: #f7faf5;
}

.edit-record-name {
  color: #2f382d;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.32;
}

.edit-record-kind {
  margin-top: 8rpx;
  color: #6d7a66;
  font-size: 23rpx;
  font-weight: 800;
}

.edit-field-label {
  margin: 28rpx 0 12rpx 8rpx;
  color: #7f8a78;
  font-size: 25rpx;
  font-weight: 900;
}

.edit-cost-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 190rpx;
  gap: 12rpx;
}

.edit-cost-input {
  width: 100%;
  height: 84rpx;
  padding: 0 22rpx;
  border: 1rpx solid #dbe8cc;
  border-radius: 22rpx;
  box-sizing: border-box;
  color: #2f382d;
  font-size: 32rpx;
  font-weight: 900;
  background: #fbfff1;
}

.edit-stepper {
  display: grid;
  grid-template-columns: 1fr 1rpx 1fr;
  align-items: center;
  height: 84rpx;
  border-radius: 22rpx;
  background: #e9f3ec;
}

.edit-stepper-button {
  color: #596552;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 84rpx;
  text-align: center;
}

.edit-stepper-divider {
  height: 42rpx;
  background: rgba(89, 101, 82, 0.22);
}

.edit-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 30rpx;
}

.edit-action {
  height: 78rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 78rpx;
  text-align: center;
}

.edit-action.secondary {
  color: #596552;
  background: #e9f3ec;
}

.edit-action.primary {
  color: #ffffff;
  background: #e24b45;
}
