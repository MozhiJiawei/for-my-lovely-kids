.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 64rpx 40rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
}

.body {
  margin-top: 24rpx;
  font-size: 30rpx;
  line-height: 1.6;
}

.e2e-marker {
  margin-top: 20rpx;
  color: #64748b;
  font-size: 22rpx;
  letter-spacing: 0;
}

.report-button {
  margin-top: 40rpx;
  background: #15803d;
  color: #ffffff;
  font-size: 30rpx;
}
